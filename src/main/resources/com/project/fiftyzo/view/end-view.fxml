<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.fiftyzo.controller.EndController">
    <center>
        <VBox alignment="CENTER" spacing="16" styleClass="menu-panel">
            <padding><Insets top="36" right="60" bottom="36" left="60" /></padding>
            <Label fx:id="resultTitleLabel" styleClass="title-label" wrapText="true" />
            <Label fx:id="winnerLabel" styleClass="winner-label" />
            <Label text="FINAL EVENT LOG" styleClass="subtitle-label" />
            <ScrollPane fitToWidth="true" prefHeight="260" styleClass="event-log">
                <content>
                    <VBox fx:id="finalLogBox" spacing="8">
                        <padding><Insets top="12" right="12" bottom="12" left="12" /></padding>
                    </VBox>
                </content>
            </ScrollPane>
            <Button fx:id="playAgainButton" text="PLAY AGAIN" onAction="#handlePlayAgain" styleClass="neon-button" />
            <Button fx:id="exitButton" text="EXIT" onAction="#handleExit" styleClass="neon-button danger-button" />
        </VBox>
    </center>
</BorderPane>
