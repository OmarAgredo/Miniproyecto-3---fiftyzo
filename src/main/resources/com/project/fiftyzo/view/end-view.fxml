<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import java.lang.String?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="760" prefWidth="1100" styleClass="end-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.fiftyzo.controller.EndController">
    <children>
        <StackPane fx:id="endCanvas" maxHeight="760" maxWidth="1100" minHeight="760" minWidth="1100" prefHeight="760" prefWidth="1100" styleClass="end-canvas">
            <children>
                <StackPane maxHeight="760" maxWidth="1100" minHeight="760" minWidth="1100" prefHeight="760" prefWidth="1100" styleClass="end-scrim" />

                <VBox alignment="CENTER" maxWidth="680" spacing="18" styleClass="end-screen-shell">
                    <children>
                        <VBox alignment="CENTER" spacing="8" styleClass="end-title-block">
                            <children>
                                <Label fx:id="resultTitleLabel" alignment="CENTER" maxWidth="640" textAlignment="CENTER" wrapText="true">
                                    <styleClass>
                                        <String fx:value="end-title-label" />
                                    </styleClass>
                                </Label>
                                <Label fx:id="winnerLabel" alignment="CENTER" maxWidth="520" textAlignment="CENTER">
                                    <styleClass>
                                        <String fx:value="end-winner-label" />
                                    </styleClass>
                                </Label>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" maxWidth="610" spacing="12">
                            <styleClass>
                                <String fx:value="event-log-panel" />
                                <String fx:value="end-log-panel" />
                            </styleClass>
                            <padding><Insets bottom="18" left="18" right="18" top="18" /></padding>
                            <children>
                                <Label text="FINAL EVENT LOG">
                                    <styleClass>
                                        <String fx:value="event-log-title" />
                                        <String fx:value="end-log-title" />
                                    </styleClass>
                                </Label>
                                <ScrollPane fitToWidth="true" prefHeight="280">
                                    <styleClass>
                                        <String fx:value="event-log-body" />
                                        <String fx:value="end-log-scroll" />
                                    </styleClass>
                                    <content>
                                        <VBox fx:id="finalLogBox" spacing="8">
                                            <styleClass>
                                                <String fx:value="event-log-placeholder" />
                                                <String fx:value="end-log-box" />
                                            </styleClass>
                                            <padding><Insets bottom="8" left="4" right="8" top="8" /></padding>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER" spacing="14" styleClass="end-button-row">
                            <children>
                                <Button fx:id="playAgainButton" minWidth="180" onAction="#handlePlayAgain" prefWidth="180" text="PLAY AGAIN">
                                    <styleClass>
                                        <String fx:value="game-button" />
                                        <String fx:value="end-button" />
                                        <String fx:value="end-primary-button" />
                                    </styleClass>
                                </Button>
                                <Button fx:id="exitButton" minWidth="140" onAction="#handleExit" prefWidth="140" text="EXIT">
                                    <styleClass>
                                        <String fx:value="game-button" />
                                        <String fx:value="game-button-danger" />
                                        <String fx:value="end-button" />
                                        <String fx:value="end-danger-button" />
                                    </styleClass>
                                </Button>
                            </children>
                        </HBox>

                        <Label text="The room resets when you do." styleClass="end-footer-label" />
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</StackPane>
