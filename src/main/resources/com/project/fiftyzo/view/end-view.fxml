<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane prefHeight="760" prefWidth="1100" styleClass="end-root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.fiftyzo.controller.EndController">
    <children>
        <StackPane fx:id="endCanvas" maxHeight="760" maxWidth="1100" minHeight="760" minWidth="1100" prefHeight="760" prefWidth="1100" styleClass="end-canvas">
            <children>
                <StackPane maxHeight="760" maxWidth="1100" minHeight="760" minWidth="1100" prefHeight="760" prefWidth="1100" styleClass="end-scrim" />

                <VBox alignment="CENTER" maxWidth="680" spacing="18" styleClass="end-screen-shell">
                    <children>
                        <VBox alignment="CENTER" spacing="8" styleClass="end-title-block">
                            <children>
                                <Label fx:id="resultTitleLabel" alignment="CENTER" maxWidth="640" styleClass="title-label end-title-label" textAlignment="CENTER" wrapText="true" />
                                <Label fx:id="winnerLabel" alignment="CENTER" maxWidth="520" styleClass="winner-label end-winner-label" textAlignment="CENTER" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" maxWidth="560" spacing="12" styleClass="event-log-panel end-log-panel">
                            <padding><Insets bottom="18" left="18" right="18" top="18" /></padding>
                            <children>
                                <Label text="FINAL EVENT LOG" styleClass="subtitle-label event-log-title end-log-title" />
                                <ScrollPane fitToWidth="true" prefHeight="270" styleClass="event-log-body end-log-body">
                                    <content>
                                        <VBox fx:id="finalLogBox" spacing="8" styleClass="event-log-placeholder end-log-box">
                                            <padding><Insets bottom="8" left="4" right="8" top="8" /></padding>
                                        </VBox>
                                    </content>
                                </ScrollPane>
                            </children>
                        </VBox>

                        <HBox alignment="CENTER" spacing="14" styleClass="end-action-row">
                            <children>
                                <Button fx:id="playAgainButton" minWidth="180" onAction="#handlePlayAgain" prefWidth="180" text="PLAY AGAIN" styleClass="game-button end-button" />
                                <Button fx:id="exitButton" minWidth="140" onAction="#handleExit" prefWidth="140" text="EXIT" styleClass="game-button game-button-danger end-button" />
                            </children>
                        </HBox>

                        <Label text="The room resets when you do." styleClass="hint-label end-footer-label" />
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</StackPane>
