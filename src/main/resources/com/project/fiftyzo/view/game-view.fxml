<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.fiftyzo.controller.GameController" fitToWidth="true" hbarPolicy="AS_NEEDED" pannable="true" styleClass="game-root game-scroll" vbarPolicy="AS_NEEDED">
    <content>
        <BorderPane styleClass="game-shell">
            <padding><Insets top="10" right="10" bottom="10" left="10" /></padding>
            <top>
                <HBox fx:id="machinePlayersContainer" alignment="CENTER" spacing="14" styleClass="machine-container">
                    <BorderPane.margin><Insets top="0" right="4" bottom="6" left="4" /></BorderPane.margin>
                </HBox>
            </top>
            <center>
                <VBox alignment="CENTER" spacing="10" styleClass="game-panel">
                    <BorderPane.margin><Insets top="0" right="6" bottom="8" left="0" /></BorderPane.margin>
                    <padding><Insets top="18" right="24" bottom="18" left="24" /></padding>
                    <Label text="CURRENT TABLE SUM" styleClass="sum-title" />
                    <Label fx:id="currentSumLabel" text="0" styleClass="sum-safe" />
                    <HBox alignment="CENTER" spacing="44" styleClass="deck-table-row">
                        <VBox fx:id="deckContainer" alignment="CENTER" spacing="7" styleClass="card-slot" />
                        <VBox fx:id="tableCardContainer" alignment="CENTER" spacing="7" styleClass="card-slot" />
                    </HBox>
                    <Label fx:id="turnMessageLabel" wrapText="true" styleClass="turn-message" />
                </VBox>
            </center>
            <right>
                <VBox styleClass="event-log" prefWidth="270" spacing="8">
                    <BorderPane.margin><Insets top="0" right="0" bottom="8" left="6" /></BorderPane.margin>
                    <padding><Insets top="16" right="14" bottom="16" left="14" /></padding>
                    <Label text="EVENT LOG" styleClass="log-title" />
                    <ScrollPane fx:id="eventLogScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS">
                        <content><VBox fx:id="eventLogBox" spacing="8" /></content>
                    </ScrollPane>
                </VBox>
            </right>
            <bottom>
                <VBox alignment="CENTER" spacing="8" styleClass="human-area">
                    <BorderPane.margin><Insets top="0" right="4" bottom="0" left="4" /></BorderPane.margin>
                    <padding><Insets top="10" right="22" bottom="14" left="22" /></padding>
                    <Label fx:id="humanNameLabel" text="YOUR HAND" styleClass="human-name" />
                    <HBox fx:id="humanHandContainer" alignment="CENTER" spacing="9" />
                </VBox>
            </bottom>
        </BorderPane>
    </content>
</ScrollPane>
