<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.fiftyzo.controller.GameController" styleClass="game-root">
    <top>
        <HBox fx:id="machinePlayersContainer" alignment="CENTER" spacing="18" styleClass="machine-container">
            <BorderPane.margin><Insets top="20" right="24" bottom="10" left="24" /></BorderPane.margin>
        </HBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="14" styleClass="game-panel">
            <padding><Insets top="20" right="25" bottom="20" left="25" /></padding>
            <Label text="CURRENT TABLE SUM" styleClass="sum-title" />
            <Label fx:id="currentSumLabel" text="0" styleClass="sum-safe" />
            <HBox alignment="CENTER" spacing="45">
                <VBox fx:id="deckContainer" alignment="CENTER" spacing="8" />
                <VBox fx:id="tableCardContainer" alignment="CENTER" spacing="8" />
            </HBox>
            <Label fx:id="turnMessageLabel" wrapText="true" styleClass="turn-message" />
        </VBox>
    </center>
    <right>
        <VBox styleClass="event-log" prefWidth="275" spacing="8">
            <padding><Insets top="20" right="14" bottom="20" left="14" /></padding>
            <Label text="EVENT LOG" styleClass="log-title" />
            <ScrollPane fx:id="eventLogScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS">
                <content><VBox fx:id="eventLogBox" spacing="8" /></content>
            </ScrollPane>
        </VBox>
    </right>
    <bottom>
        <VBox alignment="CENTER" spacing="10" styleClass="human-area">
            <padding><Insets top="12" right="24" bottom="22" left="24" /></padding>
            <Label fx:id="humanNameLabel" text="YOUR HAND" styleClass="human-name" />
            <HBox fx:id="humanHandContainer" alignment="CENTER" spacing="10" />
        </VBox>
    </bottom>
</BorderPane>
