<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.project.fiftyzo.controller.StartController">
    <center>
        <VBox alignment="CENTER" spacing="18" styleClass="menu-panel" BorderPane.alignment="CENTER">
            <padding><Insets top="40" right="55" bottom="40" left="55" /></padding>
            <Label fx:id="titleLabel" text="50ZO" styleClass="title-label" />
            <Label fx:id="subtitleLabel" text="A LIMINAL CARD SURVIVAL GAME" styleClass="subtitle-label" />
            <Label fx:id="instructionLabel" wrapText="true" styleClass="instruction-label" />
            <ComboBox fx:id="machineCountComboBox" promptText="Machine players" maxWidth="220" />
            <Button fx:id="startButton" text="START GAME" onAction="#handleStartGame" styleClass="game-button" />
            <Label text="Keep the table sum at 50 or below." styleClass="hint-label" />
        </VBox>
    </center>
</BorderPane>
